{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pi worker structured result",
  "description": "A permissive structured result shared by Pi workers and orchestrators.",
  "type": "object",
  "required": [
    "status",
    "result"
  ],
  "properties": {
    "status": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": {}
    },
    "next": {},
    "risk": {}
  },
  "additionalProperties": true
}
